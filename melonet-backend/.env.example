# Application
APP_ENV=development
HTTP_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Database
DATABASE_URL=postgres://melonet:melonet@postgres:5432/melonet?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# Object storage (MinIO in local development)
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=melonet
STORAGE_SECRET_KEY=melonetsecret
STORAGE_BUCKET=melonet-media
STORAGE_USE_SSL=false
STORAGE_REGION=us-east-1

# HTTP tuning
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_SHUTDOWN_TIMEOUT=10s

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://10.0.2.2:8080

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_REGISTER_PER_MIN=5
RATE_LIMIT_SEARCH_PER_MIN=60
RATE_LIMIT_CHAT_PER_MIN=120

# Reverse proxy trust (comma-separated IPs/CIDRs, optional)
TRUSTED_PROXIES=

# Migrations
MIGRATIONS_PATH=/app/migrations

# Media seed cache (Open Lo-Fi zip download)
SEED_CACHE_DIR=/app/data/.cache

# Audius live proxy (runtime API)
AUDIUS_APP_NAME=MeloNet
